{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenAPI Mock Management API",
    "description": "Management API for the OpenAPI mock server used in e2e testing. Provides endpoints to retrieve recorded HTTP/OpenAPI calls and clear logs.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:9000",
      "description": "Default management server"
    }
  ],
  "paths": {
    "/logs": {
      "get": {
        "summary": "Get all recorded HTTP/OpenAPI calls",
        "description": "Returns all recorded HTTP/OpenAPI calls as JSON array, including request/response bodies, timestamps, errors, and panics.",
        "operationId": "getLogs",
        "responses": {
          "200": {
            "description": "Successfully retrieved logs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CallRecord"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Failed to serialize logs"
          }
        }
      }
    },
    "/clear": {
      "post": {
        "summary": "Clear all recorded HTTP/OpenAPI calls",
        "description": "Removes all recorded HTTP/OpenAPI calls from memory.",
        "operationId": "clearLogs",
        "responses": {
          "200": {
            "description": "Successfully cleared logs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "cleared"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Clear all recorded HTTP/OpenAPI calls",
        "description": "Removes all recorded HTTP/OpenAPI calls from memory.",
        "operationId": "clearLogsDelete",
        "responses": {
          "200": {
            "description": "Successfully cleared logs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "cleared"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/doc": {
      "get": {
        "summary": "Interactive Swagger UI",
        "description": "Returns an interactive Swagger UI page for exploring and testing the API.",
        "operationId": "getDoc",
        "responses": {
          "200": {
            "description": "Swagger UI HTML page",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "summary": "Get OpenAPI specification",
        "description": "Returns this OpenAPI specification as JSON.",
        "operationId": "getOpenAPI",
        "responses": {
          "200": {
            "description": "OpenAPI specification",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CallRecord": {
        "type": "object",
        "properties": {
          "request_id": {
            "type": "string",
            "description": "Unique identifier for the request"
          },
          "method": {
            "type": "string",
            "description": "Request method and resolved route template (for example, GET /pets/{petId})"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the request was received"
          },
          "request": {
            "type": "object",
            "description": "Full request body"
          },
          "response": {
            "type": "object",
            "description": "Full response body (if successful)"
          },
          "error": {
            "type": "string",
            "description": "Error message (if the call failed)"
          },
          "panic": {
            "type": "string",
            "description": "Panic message (if a panic occurred)"
          },
          "duration_ms": {
            "type": "integer",
            "format": "int64",
            "description": "Request duration in milliseconds"
          }
        }
      }
    }
  }
}
