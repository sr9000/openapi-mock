# Скопируйте в .env и при необходимости переопределите значения для локального запуска.

# Server Configuration
HTTP_PORT=8080
METRICS_PORT=9100
MGMT_PORT=9000
# HTTP Options
HTTP_LOGGING=false
# Logging / tracing defaults for the observability stack
LOG_FORMAT=json
LOG_OUTPUT=file
TRACE_ENABLED=true
TRACE_SAMPLING_RATIO=1.0
# Monitoring Configuration
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
